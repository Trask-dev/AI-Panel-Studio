# =============================================================================
# AI Panel Studio — 环境变量配置模板
# 使用方式: cp .env.example .env 然后填入实际值
# =============================================================================

# LLM API 密钥（必填）
LLM_API_KEY=sk-your-deepseek-api-key

# LLM 模型（可选，默认 deepseek-v4-flash）
LLM_MODEL=deepseek-v4-flash

# LLM API 地址（可选，默认 Deepseek 官方）
LLM_BASE_URL=https://api.deepseek.com

# 请求超时（秒），默认 30
LLM_TIMEOUT=30

# 失败重试次数，默认 1
LLM_MAX_RETRIES=1

# SQLite 数据库路径
DATABASE_URL=sqlite:///data/dev.db

# 服务端口，默认 8000
SERVER_PORT=8000

# 调试模式
DEBUG=true
