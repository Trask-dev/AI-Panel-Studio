# =============================================================================
# AI Panel Studio — 环境变量配置模板
# =============================================================================
# 使用方式: 复制此文件为 .env 并填入实际值
#   cp .env.example .env
#
# 注意: .env 已加入 .gitignore，不会被提交到版本控制。
#       .env.example 应提交到版本控制，作为配置参考。
# =============================================================================


# =============================================================================
# LLM 大模型配置
# =============================================================================

# LLM API 密钥（必填）
# 支持 Anthropic Claude API / OpenAI API / 其他兼容接口
LLM_API_KEY=your_api_key_here

# LLM 模型标识
# Claude: claude-sonnet-4-20250514 / claude-opus-4-20250514
# OpenAI: gpt-4o / gpt-4-turbo
LLM_MODEL=claude-sonnet-4-20250514

# LLM API 基础 URL
# Anthropic: https://api.anthropic.com/v1
# OpenAI:   https://api.openai.com/v1
# 本地代理:  http://localhost:8080/v1
LLM_BASE_URL=https://api.anthropic.com/v1

# LLM 请求超时时间（秒）
LLM_TIMEOUT=30

# LLM 调用失败最大重试次数
LLM_MAX_RETRIES=1


# =============================================================================
# 数据库配置
# =============================================================================

# SQLite 数据库文件路径
# 开发环境: sqlite:///data/dev.db
# 测试环境: sqlite:///:memory: (自动)
DATABASE_URL=sqlite:///data/dev.db


# =============================================================================
# 服务器配置
# =============================================================================

# FastAPI 服务端口
SERVER_PORT=8000

# FastAPI 服务主机
# 本地开发: 127.0.0.1
# 局域网访问: 0.0.0.0
SERVER_HOST=127.0.0.1

# 调试模式 (true/false)
# 开启后启用 FastAPI auto-reload + 详细错误信息
DEBUG=true


# =============================================================================
# 跨域 (CORS) 配置
# =============================================================================

# 允许的前端域名（多个用逗号分隔）
# 开发环境通常包括 Vite 默认端口 5173 和 Live Server 端口 5500
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5500


# =============================================================================
# 应用默认配置
# =============================================================================

# 默认最大讨论轮次（用户可在创建讨论时覆盖）
DEFAULT_MAX_ROUNDS=10

# 默认专家人数（用户可在创建讨论时覆盖）
DEFAULT_EXPERT_COUNT=4

# SSE 心跳间隔（秒）
SSE_HEARTBEAT_INTERVAL=15


# =============================================================================
# 可选：生产环境配置
# =============================================================================

# 生产模式（关闭 debug 和 auto-reload）
# ENV=production

# 日志级别: DEBUG / INFO / WARNING / ERROR
# LOG_LEVEL=INFO

# Sentry DSN（错误监控，可选）
# SENTRY_DSN=
